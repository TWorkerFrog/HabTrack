<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_habit"
            android:tint="@color/orange_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Создать аккаунт"
            android:textSize="24sp"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Заполните поля ниже"
            android:textSize="14sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- Поле Логин -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Логин"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_register_login"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Придумайте логин"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:fontFamily="@font/montserrat"
            android:padding="12dp"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Поле Пароль -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Пароль"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_register_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Придумайте пароль"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:fontFamily="@font/montserrat"
            android:padding="12dp"
            android:background="@drawable/bg_edit_text"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp"/>

        <!-- Поле Подтверждение пароля -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Подтвердите пароль"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_register_confirm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Повторите пароль"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:fontFamily="@font/montserrat"
            android:padding="12dp"
            android:background="@drawable/bg_edit_text"
            android:inputType="textPassword"
            android:layout_marginBottom="24dp"/>

        <!-- Кнопка Регистрации (залитая) -->
        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Зарегистрироваться"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"/>

        <!-- Кнопка Назад к входу (обводка, без заливки) -->
        <TextView
            android:id="@+id/btn_back_to_login"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Назад к входу"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/orange_primary"
            android:gravity="center"
            android:background="@drawable/bg_button_secondary"
            android:padding="12dp"/>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/error_red"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>