<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Заголовок секции с кнопкой раскрытия -->
    <LinearLayout
        android:id="@+id/layout_categories_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Категории"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_categories_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/text_hint"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:alpha="0.6"/>

    </LinearLayout>

    <!-- Список категорий (скрыт по умолчанию) -->
    <LinearLayout
        android:id="@+id/layout_categories_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <Button
            android:id="@+id/btn_add_category"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ Добавить категорию"
            android:textSize="13sp"
            android:fontFamily="@font/montserrat"
            android:backgroundTint="@color/orange_light"
            android:textColor="@color/orange_primary"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Выйти из аккаунта"
        android:textSize="14sp"
        android:fontFamily="@font/montserrat_bold"
        android:background="@drawable/bg_button_secondary"
        android:textColor="@color/white"
        android:backgroundTint="@color/white"
        android:stateListAnimator="@null"/>
</LinearLayout>