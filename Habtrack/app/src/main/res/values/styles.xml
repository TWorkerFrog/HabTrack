<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HabTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_light</item>
        <item name="colorOnSecondary">@color/orange_primary</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">@font/montserrat</item>
    </style>

    <style name="ToolbarTitle">
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="CustomSpinner" parent="Widget.AppCompat.Spinner">
        <item name="android:popupBackground">@color/white</item>
        <item name="android:background">@drawable/spinner_background</item>
    </style>

    <style name="PopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_menu_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/montserrat</item>
    </style>

    <style name="MyPopupMenuTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:popupBackground">@drawable/popup_menu_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:colorBackground">@color/white</item>
    </style>

</resources>